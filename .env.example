# Groq API key — get free at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# Qdrant Cloud — get free tier at https://cloud.qdrant.io
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Google Gemini — optional fallback. Get free at https://aistudio.google.com
GOOGLE_API_KEY=your_gemini_key_here

# Vapi — voice integration. Get $30 free with code 'vapixhackblr' at https://vapi.ai
VAPI_API_KEY=your_vapi_key_here
